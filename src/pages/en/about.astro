---
import FontCredit from '@/components/FontCredit.astro'
import IntroSections from '@/components/IntroSections.astro'
import SiteFooter from '@/components/SiteFooter.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getDictionary } from '@/lib/i18n'

const dict = getDictionary('en-US')
const pageDict = { ...dict, pagePath: '/en/about' }
---

<BaseLayout dict={pageDict}>
  <div class="site-main">
    <IntroSections dict={dict} />
    <FontCredit dict={dict} />
    <SiteFooter dict={dict} />
  </div>
</BaseLayout>
